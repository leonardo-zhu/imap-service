# ── HTTP Server ────────────────────────────────────────────────────────────
# Port for the internal control API (e.g. POST /mail/mark-read).
HTTP_PORT=2525

# ── OpenClaw (global, shared with other services) ──────────────────────────
OPENCLAW_WEBHOOK_URL=http://your-openclaw-server/api/webhook
OPENCLAW_HOOKS_TOKEN=your_secure_token_here

# ── IMAP Accounts (imap-service specific) ───────────────────────────────────
# Multi-account mode (recommended): set IMAP_ACCOUNTS as a JSON array.
# Each object must have: host, port, user, pass, label (label is optional but helpful for log output).
#
# IMAP_ACCOUNTS=[{"host":"imap.qq.com","port":993,"user":"you@qq.com","pass":"authcode","label":"qq"},{"host":"imap.gmail.com","port":993,"user":"you@gmail.com","pass":"app-password","label":"gmail"}]

IMAP_ACCOUNTS=[{"host":"imap.qq.com","port":993,"user":"you@qq.com","pass":"authcode","label":"qq"},{"host":"imap.gmail.com","port":993,"user":"you@gmail.com","pass":"app-password","label":"gmail"}]

