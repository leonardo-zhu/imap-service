IMAP_HOST=imap.qq.com
IMAP_PORT=993
IMAP_USER=your_qq_number@qq.com
IMAP_PASS=your_qq_mail_auth_code

# The Webhook URL provided by OpenClaw to accept pushed messages
OPENCLAW_WEBHOOK_URL=http://your-openclaw-server/api/webhook/email
# The authentication token for OpenClaw Webhooks
OPENCLAW_HOOKS_TOKEN=your_secure_token_here
